// HP予約カレンダー機能 Phase 1 スキャフォールド
// 詳細仕様は Notion タスクページ「HP予約カレンダー機能の方針確定と実装」を参照
//
// Phase 1 スコープ：Auth.js v5 標準スキーマ + 予約者プロフィール（Customer）+ 予約（Booking）
// 仮キープの 3日タイマー用フィールドと、GCal 仮キープイベント連携用の gcalEventId を初版から含める
// 後続 Phase で予約 UI / GCal 連携 / 3日タイマーバッチを実装する

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("TURSO_DATABASE_URL")
}

// ─────────────────────────────────────────────────
// Auth.js v5 標準スキーマ
// ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // Credentials Provider 用 自前パスワード（bcrypt ハッシュ）
  // OAuth ログインのみのユーザーは null のまま
  passwordHash  String?

  accounts Account[]
  sessions Session[]
  customer Customer?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────
// 予約者プロフィール
// ─────────────────────────────────────────────────

model Customer {
  id          String  @id @default(cuid())
  userId      String  @unique
  displayName String
  phone       String?
  companyName String?
  notes       String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────
// 予約
// ─────────────────────────────────────────────────
//
// status は以下の文字列のいずれかを取る（SQLite は enum 非対応のため文字列で表現）：
//   - TENTATIVE             : 顧客が「仮キープ」として置いた予約。GCal にも仮キープ用の色 / タイトル prefix で書き込み
//   - PENDING_CONFIRMATION  : 同枠に他客の本予約申込が入って 3日タイマー稼働中の仮キープ
//   - CONFIRMED             : 本予約として確定
//   - OVERWRITTEN           : 3日タイマー失効で後着の本予約により上書きされた仮キープ
//   - CANCELLED             : 顧客 / さとし側でキャンセル
//
// 仮キープも GCal にイベントを書き込むため、gcalEventId は仮キープ作成時点で先行作成される。
// 本予約確定 / 上書き / キャンセル時には GCal イベントの色・タイトル・状態を更新するか削除する。

model Booking {
  id         String   @id @default(cuid())
  customerId String
  startTime  DateTime
  endTime    DateTime
  title      String
  memo       String?
  status     String   @default("CONFIRMED")

  // 仮キープの 3日タイマー
  tentativeNotifiedAt DateTime?
  tentativeDeadlineAt DateTime?

  // Google Calendar Event ID（仮キープ作成時点で先行作成 → 本予約確定 / 上書き / キャンセル時に色・タイトル・状態を更新）
  gcalEventId String?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime, endTime])
  @@index([status])
}
