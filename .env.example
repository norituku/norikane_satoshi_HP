# HP予約カレンダー機能 Phase 1 環境変数
# 詳細は Notion タスクページ「HP予約カレンダー機能の方針確定と実装」を参照
# シークレット系は Vercel デフォルトで Sensitive 扱いとなり Development が鍵でロック。Production / Preview のみ投入し、ローカル dev は .env.local（git 管理外）で補完する。非シークレット定数は Sensitive 解除トグルで3環境投入可

# ───────────── Auth.js v5 ─────────────
# AUTH_SECRET は `openssl rand -base64 32` で生成
AUTH_SECRET=
# 本番は https://norikane.studio（apex canonical、2026-05-03 から稼働）、Preview は Vercel が自動補完するため未設定でよい
AUTH_URL=http://localhost:41237

# ───────────── Turso（HP 予約用 DB。colorist-scheduler とは別 DB） ─────────────
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ───────────── OAuth Provider: Google ─────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ───────────── OAuth Provider: X (Twitter) ─────────────
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# ───────────── OAuth Provider: LINE ─────────────
AUTH_LINE_ID=
AUTH_LINE_SECRET=

# ───────────── Resend（メール送信。独自ドメイン + SPF/DKIM 設定済みのアドレス） ─────────────
# API キーは 1Password 保管、Vercel env は Production / Preview に Sensitive 投入済み、ローカル dev は .env.local に手動投入する運用
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@norikane.studio

# ───────────── Upstash Redis（レート制限。Phase 1-D/E で使用） ─────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Cron 用 Bearer 認証シークレット。`openssl rand -base64 32` で生成
CRON_SECRET=your-cron-secret-here
# Calendar OAuth refresh token revoke の通知先。未設定なら RESEND_FROM_EMAIL に fallback
BOOKING_CALENDAR_ADMIN_EMAIL=norikane.satoshi@gmail.com

# ───────────── AI チャットボット Tier 1/2 ─────────────
NOTION_AI_CHATBOT_THREAD_URL=https://www.notion.so/chat?t=36b13ee3141a8073885d00a99ebb676c
CHATBOT_TIER1_CDP_BASE_URL=http://127.0.0.1:9223
CHATBOT_MAIN_CHROME_CDP_BASE_URL=http://127.0.0.1:9222
CHATBOT_TIER2_OLLAMA_BASE_URL=http://127.0.0.1:11434
CHATBOT_TIER2_OLLAMA_MODEL=hf.co/mmnga/cyberagent-DeepSeek-R1-Distill-Qwen-14B-Japanese-gguf:Q4_K_M

# ───────────── Google Calendar Free/Busy 取得 + 予約イベント書き込み ─────────────
# Calendar 連携専用 OAuth Client ID（NextAuth の Google Provider とは別）
GOOGLE_CALENDAR_OAUTH_CLIENT_ID=
# Calendar 連携専用 OAuth Client Secret（Bitwarden / Vercel env / .env.local に保管）
GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=
# Calendar 連携専用 OAuth Redirect URI（例: http://localhost:41237/api/calendar/auth/callback）
GOOGLE_CALENDAR_REDIRECT_URI=
# Free/Busy 取得元の「智志仕事」Google Calendar ID
GOOGLE_CALENDAR_BUSY_SOURCE_ID=
