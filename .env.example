# HP予約カレンダー機能 Phase 1 環境変数
# 詳細は Notion タスクページ「HP予約カレンダー機能の方針確定と実装」を参照
# Vercel の Production / Preview / Development 全環境に同じキーを投入する

# ───────────── Auth.js v5 ─────────────
# AUTH_SECRET は `openssl rand -base64 32` で生成
AUTH_SECRET=
# 本番は https://norikane-satoshi-hp.vercel.app、Preview は Vercel が自動補完するため未設定でよい
AUTH_URL=http://localhost:41237

# ───────────── Turso（HP 予約用 DB。colorist-scheduler とは別 DB） ─────────────
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ───────────── OAuth Provider: Google ─────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ───────────── OAuth Provider: X (Twitter) ─────────────
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# ───────────── OAuth Provider: LINE ─────────────
AUTH_LINE_ID=
AUTH_LINE_SECRET=

# ───────────── OAuth Provider: Microsoft (Entra ID) ─────────────
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# ───────────── Resend（メール送信。独自ドメイン + SPF/DKIM 設定済みのアドレス） ─────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ───────────── Google Calendar Free/Busy 取得 + 予約イベント書き込み ─────────────
# Path to gcal-sync-sa.json (Service Account key for Free/Busy read on 智志仕事 calendar; reuse cc-notion-gcal SA)
GOOGLE_CALENDAR_SA_KEY_PATH=
